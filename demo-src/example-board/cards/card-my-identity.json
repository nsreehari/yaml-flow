{
  "id": "card-my-identity",
  "meta": {
    "title": "My Identity",
    "tags": ["m365", "workiq"],
    "desc": "Displays your M365 display name via WorkIQ (Microsoft 365 Copilot)."
  },
  "source_defs": [
    {
      "bindTo": "identity",
      "outputFile": "card-my-identity.txt",
      "workiq": {
        "query_template": "what is my full display name"
      }
    }
  ],
  "view": {
    "elements": [
      { "kind": "markdown", "label": "Display Name", "data": { "bind": "fetched_sources.identity" } }
    ],
    "layout": {
      "board": { "col": 1, "order": 10 },
      "canvas": { "x": 50, "y": 450, "w": 320, "h": 140 }
    },
    "features": { "refresh": true }
  },
  "card_data": {}
}
