{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://nsreehari.github.io/boards/live-cards.schema.json",
  "title": "LiveCards Node Schema",
  "description": "Schema for LiveCards nodes. All nodes share one flat shape: id + state required; requires/provides/sources/optionalSources/compute/view optional. computed_values is runtime-only (never in JSON).",

  "definitions": {

    "bind_ref": {
      "description": "A path into the node's runtime namespace: state.*, requires.*, or computed_values.*",
      "type": "string",
      "pattern": "^(state|requires|computed_values)\\."
    },

    "bind_or_literal": {
      "description": "A literal value or a bind reference object",
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "array" },
        { "type": "object",
          "properties": { "bind": { "$ref": "#/definitions/bind_ref" } },
          "required": ["bind"]
        }
      ]
    },

    "provides_binding": {
      "description": "Explicit binding: publish a named token downstream from a resolved path",
      "type": "object",
      "required": ["bindTo", "src"],
      "additionalProperties": false,
      "properties": {
        "bindTo": { "type": "string", "description": "Token name published downstream" },
        "src":    { "type": "string", "description": "Path to read value from (state.*, requires.*, computed_values.*)" }
      }
    },

    "compute_step": {
      "description": "A single ordered compute step: reads state.*/requires.*/computed_values.*, writes to computed_values[bindTo]",
      "type": "object",
      "required": ["bindTo", "fn"],
      "properties": {
        "bindTo": { "type": "string", "description": "Key in computed_values to write result" },
        "fn": {
          "type": "string",
          "description": "Function name from the built-in vocabulary or a custom registered function"
        },
        "input": {
          "description": "state.path, literal, array of inputs, or nested compute_expr",
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "array" },
            { "$ref": "#/definitions/compute_expr" }
          ]
        },
        "field":    { "type": "string", "description": "For pluck/sum/group — the object key to extract" },
        "where":    { "$ref": "#/definitions/compute_expr", "description": "For filter — predicate expression" },
        "apply":    { "$ref": "#/definitions/compute_expr", "description": "For map — transform expression" },
        "cond":     { "$ref": "#/definitions/compute_expr", "description": "For if — condition expression" },
        "then":     { "description": "For if — value when cond is truthy" },
        "else":     { "description": "For if — value when cond is falsy" },
        "format":   { "type": "string", "description": "For format_date / template" },
        "decimals": { "type": "integer", "description": "For round" },
        "separator":{ "type": "string", "description": "For join/split" },
        "direction":{ "enum": ["asc", "desc"], "description": "For sort" },
        "start":    { "type": "integer", "description": "For slice" },
        "end":      { "type": "integer", "description": "For slice" },
        "depth":    { "type": "integer", "description": "For flat" },
        "path":     { "type": "string", "description": "For get" },
        "value":    { "description": "For default/coalesce" }
      }
    },

    "source_entry": {
      "description": "One source definition inside sources[] or optionalSources[]. bindTo is the only required field. kind indicates the channel (api, websocket, static, llm, script, mail, teams, ...) — open-ended, extensible.",
      "type": "object",
      "required": ["bindTo"],
      "properties": {
        "bindTo":        { "type": "string", "description": "Key in state to write fetched/received data into" },
        "kind":          { "type": "string", "description": "Channel type — api | websocket | static | llm | script | mail | teams | ... (extensible)" },
        "script":        { "type": "string", "description": "Shell command or path to script (for kind: script)" },
        "url_template":  { "type": "string", "description": "URL with {{var}} placeholders (for kind: api/websocket)" },
        "method":        { "type": "string", "description": "HTTP method (for kind: api)" },
        "headers":       { "type": "object", "additionalProperties": true },
        "body_template": { "type": "object", "additionalProperties": true },
        "template_vars": { "type": "object", "additionalProperties": true },
        "poll_interval": { "type": "integer", "minimum": 0, "description": "Auto-refresh in seconds (0 = manual)" },
        "transform":     { "type": "string", "description": "Dot-path to extract from response, e.g. 'data.items'" }
      },
      "additionalProperties": true
    },
      "description": "A declarative JSON compute expression",
      "type": "object",
      "required": ["fn"],
      "properties": {
        "fn": {
          "type": "string",
          "description": "Function name from the built-in vocabulary",
          "enum": [
            "sum", "avg", "min", "max", "count", "first", "last",
            "add", "sub", "mul", "div", "round", "abs", "mod",
            "gt", "gte", "lt", "lte", "eq", "neq",
            "if", "and", "or", "not",
            "concat", "upper", "lower", "template",
            "filter", "pluck", "map", "sort", "slice", "flat", "unique", "group",
            "get", "default",
            "now", "diff_days", "format_date"
          ]
        },
        "input": {
          "description": "state.path, literal, array of inputs, or nested compute_expr",
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "array" },
            { "$ref": "#/definitions/compute_expr" }
          ]
        },
        "field": { "type": "string", "description": "For pluck/sum/group — the object key to extract" },
        "where": { "$ref": "#/definitions/compute_expr", "description": "For filter — predicate expression ($ = current item)" },
        "cond":  { "$ref": "#/definitions/compute_expr", "description": "For if — condition expression" },
        "then":  { "description": "For if — value when cond is truthy" },
        "else":  { "description": "For if — value when cond is falsy" },
        "format": { "type": "string", "description": "For format_date — date format string" }
      }
    },

    "meta": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "tags":  { "type": "array", "items": { "type": "string" } }
      }
    },

    "state_obj": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "status":  { "enum": ["fresh", "stale", "loading", "error"] },
        "lastRun": { "type": "string", "format": "date-time" },
        "error":   { "type": "string" }
      }
    },

    "render_element": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "id":        { "type": "string", "description": "Optional element ID for targeted updates" },
        "kind":      {
          "enum": ["metric", "table", "chart", "form", "filter", "list",
                   "notes", "todo", "alert", "narrative", "badge", "text",
                   "markdown", "custom", "file-upload", "chat", "actions"]
        },
        "label":     { "type": "string", "description": "Heading above this element" },
        "className": { "type": "string", "description": "Bootstrap grid class, e.g. 'col-12 col-md-6'" },
        "visible":   { "type": "string", "description": "state path — element shown only if truthy" },
        "data": {
          "type": "object",
          "properties": {
            "bind":        { "$ref": "#/definitions/bind_ref", "description": "state path to read data from" },
            "writeTo":     { "$ref": "#/definitions/bind_ref", "description": "state path for user input (form, filter, todo, notes)" },
            "columns":     { "type": "array", "items": { "type": "string" }, "description": "table: visible columns" },
            "maxRows":     { "type": "integer", "description": "table/list: max rows to display" },
            "sortable":    { "type": "boolean", "default": true, "description": "table: enable click-to-sort" },
            "placeholder": { "type": "string", "description": "Empty-state message" },
            "chartType":   { "enum": ["bar", "line", "pie", "doughnut"] },
            "chartOptions": { "type": "object", "description": "Chart.js options passthrough" },
            "fields":      { "type": "object", "description": "JSON Schema for form/filter fields" },
            "thresholds":  {
              "type": "object",
              "properties": {
                "green": { "type": "string" },
                "amber": { "type": "string" }
              }
            },
            "colorMap": { "type": "object", "description": "badge: value → Bootstrap color" },
            "style":    { "enum": ["heading", "muted", "default"], "description": "text: display style" },
            "upload":   { "type": "boolean", "default": true, "description": "file-upload: show drop zone (false = read-only file list)" },
            "accept":   { "type": "array", "items": { "type": "string" }, "description": "file-upload: allowed extensions" },
            "multiple": { "type": "boolean", "default": true, "description": "file-upload: allow multiple files" },
            "fileAttach": { "type": "boolean", "default": false, "description": "chat: enable inline file attachments" },
            "fileAccept": { "type": "array", "items": { "type": "string" }, "description": "chat: allowed attachment extensions" },
            "buttons":  {
              "type": "array",
              "description": "actions: button definitions",
              "items": {
                "type": "object",
                "required": ["id", "label"],
                "properties": {
                  "id":       { "type": "string" },
                  "label":    { "type": "string" },
                  "style":    { "type": "string", "description": "Bootstrap button variant, e.g. 'success', 'outline-danger'" },
                  "size":     { "type": "string", "default": "sm" },
                  "disabled": { "oneOf": [{ "type": "boolean" }, { "type": "string", "description": "state path — truthy = disabled" }] }
                }
              }
            }
          }
        }
      }
    },

    "view": {
      "type": "object",
      "required": ["elements"],
      "properties": {
        "elements": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/render_element" }
        },
        "layout": {
          "type": "object",
          "properties": {
            "board": {
              "type": "object",
              "properties": {
                "col":   { "type": "integer", "minimum": 1, "maximum": 12 },
                "order": { "type": "integer" }
              }
            },
            "canvas": {
              "type": "object",
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" },
                "w": { "type": "number" },
                "h": { "type": "number" }
              }
            }
          }
        },
        "features": {
          "type": "object",
          "properties": {
            "chat":    { "type": "boolean", "default": false },
            "notes":   { "type": "boolean", "default": false },
            "refresh": { "type": "boolean", "default": true }
          }
        }
      }
    }
  },

  "title": "LiveCard Node",
  "description": "Unified node: id + state required. requires/provides/sources/optionalSources/compute/view all optional. No type discriminator — nodes with view render as cards; nodes without view and with sources render as source pills in canvas mode.",
  "type": "object",
  "required": ["id", "state"],
  "additionalProperties": true,
  "properties": {
    "id":    { "type": "string", "description": "Unique node identifier" },
    "meta":  { "$ref": "#/definitions/meta" },
    "state": { "$ref": "#/definitions/state_obj" },

    "requires": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of upstream nodes this node depends on"
    },

    "provides": {
      "type": "array",
      "items": { "$ref": "#/definitions/provides_binding" },
      "description": "Explicit bindings publishing named tokens downstream. Each item: { bindTo, src } where src is a state.*/requires.*/computed_values.* path."
    },

    "sources": {
      "type": "array",
      "items": { "$ref": "#/definitions/source_entry" },
      "description": "Blocking sources — all must complete before node is considered fresh. Each writes to state[bindTo]."
    },

    "optionalSources": {
      "type": "array",
      "items": { "$ref": "#/definitions/source_entry" },
      "description": "Non-blocking sources — arrivals trigger re-fire but don't gate completion."
    },

    "compute": {
      "type": "array",
      "items": { "$ref": "#/definitions/compute_step" },
      "description": "Ordered compute steps. Each reads state.*/requires.*/computed_values.* and writes to ephemeral computed_values[bindTo]. computed_values is never persisted."
    },

    "asyncHelpers": {
      "type": "object",
      "description": "Named async helper definitions (CLI/board handler feature; not evaluated by the browser engine).",
      "additionalProperties": true
    },

    "view": { "$ref": "#/definitions/view" }
  }
}
