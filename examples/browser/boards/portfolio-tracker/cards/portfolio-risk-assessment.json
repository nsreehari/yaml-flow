{
  "id": "portfolio-risk-assessment",
  "meta": {
    "title": "Portfolio Risk Assessment"
  },
  "requires": [
    "table",
    "totalValue"
  ],
  "provides": [
    {
      "bindTo": "riskAssessment",
      "ref": "card_data.llm_task_completion_inference.reason"
    }
  ],
  "card_data": {},
  "view": {
    "elements": [
      {
        "kind": "text",
        "label": "Risk Assessment",
        "data": {
          "bind": "card_data.llm_task_completion_inference.reason"
        }
      },
      {
        "kind": "text",
        "label": "Risk Evidence",
        "data": {
          "bind": "card_data.llm_task_completion_inference.evidence"
        }
      }
    ]
  }
}
