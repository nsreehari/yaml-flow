{
  "id": "portfolio-form",
  "meta": {
    "title": "Portfolio Holdings Form"
  },
  "provides": [
    {
      "bindTo": "holdings",
      "src": "state.holdings"
    }
  ],
  "state": {
    "holdings": [
      {
        "symbol": "AAPL",
        "qty": 50
      },
      {
        "symbol": "MSFT",
        "qty": 30
      },
      {
        "symbol": "GOOG",
        "qty": 100
      }
    ]
  },
  "view": {
    "elements": [
      {
        "kind": "table",
        "label": "Holdings",
        "data": {
          "bind": "state.holdings",
          "columns": [
            "symbol",
            "qty"
          ]
        }
      }
    ]
  }
}
