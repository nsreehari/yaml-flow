{
  "id": "card-ex-chat",
  "meta": {
    "title": "Collaboration Chat",
    "tags": ["chat", "interactive"],
    "desc": "Board-level chat action routing with optional file attachments"
  },
  "view": {
    "elements": [
      {
        "id": "chat-note",
        "kind": "markdown",
        "label": "Card Chat",
        "data": {
          "bind": "computed_values.note"
        }
      }
    ],
    "layout": { "board": { "col": 6, "order": 12 }, "canvas": { "x": 980, "y": 530, "w": 360, "h": 240 } }
  },
  "compute": [
    {
      "bindTo": "note",
      "expr": "'Use the Chat button on any card header to open the chat window for that card.'"
    }
  ],
  "card_data": {}
}
