{
  "id": "card-ex-inference-complete",
  "meta": {
    "title": "Inference Completion Demo",
    "tags": ["inference", "async"],
    "desc": "Demonstrates async inference completion when evidence is sufficient"
  },
  "requires": ["orders"],
  "compute": [
    {
      "bindTo": "totalRevenue",
      "expr": "$round($sum(requires.orders.amount), 2)"
    },
    {
      "bindTo": "deploymentStatus",
      "expr": "computed_values.totalRevenue >= 60000 ? 'done' : 'pending'"
    }
  ],
  "when_is_task_completed": "From the available information, confirm completion when revenue data is sufficient and deployment status is done.",
  "view": {
    "elements": [
      {
        "kind": "metric",
        "label": "Revenue",
        "data": { "bind": "computed_values.totalRevenue" }
      },
      {
        "kind": "badge",
        "label": "Inference Status",
        "data": {
          "bind": "computed_values.deploymentStatus",
          "colorMap": {
            "done": "success",
            "pending": "warning"
          }
        }
      }
    ],
    "layout": {
      "board": { "col": 4, "order": 23 },
      "canvas": { "x": 850, "y": 1100, "w": 260, "h": 180 }
    }
  },
  "card_data": {}
}
