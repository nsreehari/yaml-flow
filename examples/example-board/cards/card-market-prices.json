{
  "id": "card-market-prices",
  "meta": {
    "title": "Market Prices",
    "tags": ["prices", "market"],
    "desc": "Fetches market prices for portfolio holdings from Yahoo Finance chart API (free, per-ticker). Computes per-position value and total portfolio value."
  },
  "requires": ["holdings"],
  "sources": [
    {
      "bindTo": "quotes",
      "outputFile": "market-prices-quotes.json",
      "chartApi": {
        "url": "https://query1.finance.yahoo.com/v8/finance/chart/{{ticker}}?interval=1d&range=1d",
        "headers": {
          "User-Agent": "Mozilla/5.0 (compatible; portfolio-tracker-demo/1.0)"
        }
      },
      "tickersFrom": "holdings.ticker",
      "mock": "quotes"
    }
  ],
  "compute": [
    {
      "bindTo": "positions",
      "expr": "($holdings := $merge(requires.holdings.{ticker: quantity}); $map(fetched_sources.quotes.quoteResponse.result, function($q) { ($qty := $lookup($holdings, $q.symbol); {\"ticker\": $q.symbol, \"name\": $q.shortName, \"price\": $round($q.regularMarketPrice, 2), \"change\": $round($q.regularMarketChange, 2), \"chg_pct\": $round($q.regularMarketChangePercent, 2), \"quantity\": $qty, \"value\": $round($q.regularMarketPrice * $qty, 2)}) }))"
    },
    {
      "bindTo": "totalValue",
      "expr": "$round($sum(computed_values.positions.value), 2)"
    },
    {
      "bindTo": "gainers",
      "expr": "$count($filter(computed_values.positions, function($p){ $p.change > 0 }))"
    },
    {
      "bindTo": "losers",
      "expr": "$count($filter(computed_values.positions, function($p){ $p.change < 0 }))"
    }
  ],
  "view": {
    "elements": [
      {
        "kind": "metric",
        "label": "Portfolio Value ($)",
        "data": { "bind": "computed_values.totalValue" }
      },
      {
        "kind": "metric",
        "label": "Gainers",
        "data": { "bind": "computed_values.gainers" }
      },
      {
        "kind": "metric",
        "label": "Losers",
        "data": { "bind": "computed_values.losers" }
      },
      {
        "kind": "table",
        "label": "Positions",
        "data": {
          "bind": "computed_values.positions",
          "columns": ["ticker", "name", "price", "change", "chg_pct", "quantity", "value"],
          "sortable": true
        }
      }
    ],
    "layout": {
      "board": { "col": 8, "order": 2 },
      "canvas": { "x": 400, "y": 50, "w": 560, "h": 320 }
    },
    "features": { "refresh": true, "chat": true }
  },
  "card_data": {}
}
