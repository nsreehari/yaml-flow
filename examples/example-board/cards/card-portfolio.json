{
  "id": "card-portfolio",
  "meta": {
    "title": "My Portfolio",
    "tags": ["portfolio"],
    "desc": "Manage your stock holdings — edit tickers and quantities inline, add or delete rows. Changes propagate downstream immediately."
  },
  "provides": [
    { "bindTo": "holdings", "src": "card_data.holdings" }
  ],
  "compute": [
    {
      "bindTo": "holdingsCount",
      "expr": "$count(card_data.holdings)"
    },
    {
      "bindTo": "totalShares",
      "expr": "$sum(card_data.holdings.quantity)"
    }
  ],
  "view": {
    "elements": [
      {
        "kind": "metric",
        "label": "Positions",
        "data": { "bind": "computed_values.holdingsCount" }
      },
      {
        "kind": "metric",
        "label": "Total Shares",
        "data": { "bind": "computed_values.totalShares" }
      },
      {
        "kind": "editable-table",
        "label": "Holdings",
        "data": {
          "bind": "card_data.holdings",
          "writeTo": "card_data.holdings",
          "columns": ["ticker", "quantity"],
          "schema": {
            "properties": {
              "quantity": { "type": "number" }
            }
          }
        }
      }
    ],
    "layout": {
      "board": { "col": 4, "order": 1 },
      "canvas": { "x": 50, "y": 50, "w": 300, "h": 280 }
    },
    "features": { "chat": true }
  },
  "card_data": {
    "holdings": [
      { "ticker": "AAPL",  "quantity": 10 },
      { "ticker": "MSFT",  "quantity": 5  },
      { "ticker": "GOOGL", "quantity": 2  },
      { "ticker": "TSLA",  "quantity": 3  }
    ]
  }
}
