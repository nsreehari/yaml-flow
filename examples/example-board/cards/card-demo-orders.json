{
  "id": "card-demo-orders",
  "meta": {
    "title": "Demo Orders (Mock)",
    "tags": ["demo", "mock"],
    "desc": "Test card using demo-task-executor with mock.db lookup"
  },
  "provides": [{ "bindTo": "orders", "src": "sources.raw" }],
  "sources": [{
    "bindTo": "raw",
    "outputFile": "card-demo-orders-raw.json",
    "mock": "orders"
  }],
  "view": {
    "elements": [
      { "kind": "table", "data": { "bind": "sources.raw", "columns": ["id", "product", "quantity", "amount", "region"], "maxRows": 10 } }
    ],
    "layout": { "board": { "col": 6, "order": 1 } }
  },
  "card_data": {}
}
