{
  "id": "card-ticker-list",
  "meta": {
    "title": "Ticker List",
    "tags": ["portfolio"],
    "desc": "Displays the tickers from the portfolio as a comma-separated list."
  },
  "requires": ["holdings"],
  "compute": [
    {
      "bindTo": "tickerList",
      "expr": "$join(requires.holdings.ticker, ', ')"
    },
    {
      "bindTo": "tickerCount",
      "expr": "$count(requires.holdings)"
    }
  ],
  "view": {
    "elements": [
      {
        "kind": "metric",
        "label": "Tickers",
        "data": { "bind": "computed_values.tickerCount" }
      },
      {
        "kind": "text",
        "label": "Ticker List",
        "data": { "bind": "computed_values.tickerList" }
      }
    ],
    "layout": {
      "board": { "col": 4, "order": 3 },
      "canvas": { "x": 50, "y": 360, "w": 300, "h": 120 }
    }
  }
}
