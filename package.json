{
  "name": "yaml-flow",
  "version": "5.4.2",
  "description": "Unified workflow engine: step-machine (sequential) + event-graph (stateless DAG) with pluggable storage",
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "board-live-cards-cli": "./board-live-cards-cli.js",
    "step-machine-cli": "./step-machine-cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./step-machine": {
      "types": "./dist/step-machine/index.d.ts",
      "import": "./dist/step-machine/index.js",
      "require": "./dist/step-machine/index.cjs"
    },
    "./event-graph": {
      "types": "./dist/event-graph/index.d.ts",
      "import": "./dist/event-graph/index.js",
      "require": "./dist/event-graph/index.cjs"
    },
    "./stores": {
      "types": "./dist/stores/index.d.ts",
      "import": "./dist/stores/index.js",
      "require": "./dist/stores/index.cjs"
    },
    "./stores/memory": {
      "types": "./dist/stores/memory.d.ts",
      "import": "./dist/stores/memory.js",
      "require": "./dist/stores/memory.cjs"
    },
    "./stores/localStorage": {
      "types": "./dist/stores/localStorage.d.ts",
      "import": "./dist/stores/localStorage.js",
      "require": "./dist/stores/localStorage.cjs"
    },
    "./stores/file": {
      "types": "./dist/stores/file.d.ts",
      "import": "./dist/stores/file.js",
      "require": "./dist/stores/file.cjs"
    },
    "./batch": {
      "types": "./dist/batch/index.d.ts",
      "import": "./dist/batch/index.js",
      "require": "./dist/batch/index.cjs"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "require": "./dist/config/index.cjs"
    },
    "./continuous-event-graph": {
      "types": "./dist/continuous-event-graph/index.d.ts",
      "import": "./dist/continuous-event-graph/index.js",
      "require": "./dist/continuous-event-graph/index.cjs"
    },
    "./board-livegraph-runtime": {
      "types": "./dist/board-livegraph-runtime/index.d.ts",
      "import": "./dist/board-livegraph-runtime/index.js",
      "require": "./dist/board-livegraph-runtime/index.cjs"
    },
    "./inference": {
      "types": "./dist/inference/index.d.ts",
      "import": "./dist/inference/index.js",
      "require": "./dist/inference/index.cjs"
    },
    "./card-compute": {
      "types": "./dist/card-compute/index.d.ts",
      "import": "./dist/card-compute/index.js",
      "require": "./dist/card-compute/index.cjs"
    },
    "./runtime-artifacts": {
      "types": "./dist/runtime-artifacts/index.d.ts",
      "import": "./dist/runtime-artifacts/index.js",
      "require": "./dist/runtime-artifacts/index.cjs"
    },
    "./board-livecards-server-runtime": "./board-livecards-server-runtime.js",
    "./package.json": "./package.json"
  },
  "browser": {
    "./stores/file": false
  },
  "files": [
    "board-live-cards-cli.js",
    "step-machine-cli.js",
    "board-livecards-server-runtime.js",
    "dist",
    "schema",
    "browser",
    "examples"
  ],
  "scripts": {
    "build": "tsup",
    "build:browser": "tsup --config tsup.browser.config.ts",
    "build:example": "node demo-src/example-board/build.js",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "test:example-board": "vitest run tests/examples/example-board.test.ts",
    "check:example-board": "npm run test:example-board && npm run validate:cards -- \"examples/example-board/cards/*.json\"",
    "validate:cards": "tsx scripts/validate-live-cards.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run build:browser"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/proper-lockfile": "^4.1.4",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "ajv-formats": "^3.0.1",
    "fast-glob": "^3.3.3",
    "jsonata": "^2.1.0",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.3.4"
  },
  "optionalDependencies": {
    "ajv": "^8.18.0"
  },
  "keywords": [
    "workflow",
    "state-machine",
    "yaml",
    "flow",
    "isomorphic",
    "browser",
    "nodejs",
    "declarative"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nsreehari/yaml-flow.git"
  },
  "engines": {
    "node": ">=18"
  }
}
